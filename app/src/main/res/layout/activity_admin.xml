<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/kid_font"
        android:text="BACK"
        android:textColor="#FFFFFF"
        app:backgroundTint="#F44336"
        app:cornerRadius="20dp"
        app:icon="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangePin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/kid_font"
        android:text="RESET PIN"
        android:textColor="#333333"
        app:icon="@android:drawable/ic_secure"
        app:iconTint="#333333"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAdminTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:fontFamily="@font/kid_font"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="ADMIN PANEL"
        android:textColor="#333333"
        android:textSize="32sp"
        app:autoSizeMaxTextSize="32sp"
        app:autoSizeMinTextSize="18sp"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAdminTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminUserLogs"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="HISTORY LOGS\n(User Collection)"
                    android:textColor="#FF9800"
                    app:backgroundTint="#FFF3E0"
                    app:icon="@android:drawable/ic_menu_today"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#FF9800" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminPlayerLogs"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="Profile(s) LOGS\n(Monitor Profile)"
                    android:textColor="#009688"
                    app:backgroundTint="#E0F2F1"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#009688" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuizScores"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="QUIZ RECORDS\n(Student Scores)"
                    android:textColor="#9C27B0"
                    app:backgroundTint="#F3E5F5"
                    app:icon="@android:drawable/ic_menu_sort_by_size"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#9C27B0" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminAddObject"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="ADD NEW OBJECT\nTO ALMANAC"
                    android:textColor="#4CAF50"
                    app:backgroundTint="#E8F5E9"
                    app:icon="@android:drawable/ic_menu_add"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#4CAF50" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditAlmanac"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="EDIT ALMANAC\n(Select Quiz Words)"
                    android:textColor="#3F51B5"
                    app:backgroundTint="#E8EAF6"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#3F51B5" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeletedLogs"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="DELETED ITEMS\nHISTORY"
                    android:textColor="#F44336"
                    app:backgroundTint="#FFEBEE"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#F44336" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageStorage"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kid_font"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="85dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="MANAGE STORAGE"
                    android:textColor="#616161"
                    app:backgroundTint="#EEEEEE"
                    app:icon="@android:drawable/ic_menu_manage"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconSize="32dp"
                    app:iconTint="#616161" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>