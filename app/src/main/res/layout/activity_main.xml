<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/menu_background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExit"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/kid_font"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="EXIT"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#F44336"
        app:cornerRadius="25dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconTint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivTitleLogo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/title_logo"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/playerBadgeCard"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.4" />
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/playerBadgeCard"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="#88000000"
        app:cardCornerRadius="30dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintWidth_percent="0.65"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivTitleLogo"
        app:layout_constraintBottom_toTopOf="@+id/btnPlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/tvActivePlayerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:fontFamily="@font/kid_font"
                android:text="Select Player"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                android:ellipsize="end" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivActivePlayerPic"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:scaleType="centerCrop"
                android:src="@drawable/admin_pic"
                app:cornerFamily="rounded"
                app:cornerSize="50%" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="90dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/kid_font"
        android:text="PLAY"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        app:autoSizeTextType="uniform"
        app:autoSizeMaxTextSize="40sp"
        app:autoSizeMinTextSize="20sp"
        app:backgroundTint="#4CAF50"
        app:cornerRadius="40dp"
        app:elevation="12dp"
        app:icon="@android:drawable/ic_media_play"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="48dp"
        app:iconTint="#FFFFFF"
        app:layout_constraintWidth_percent="0.80"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/playerBadgeCard"
        app:layout_constraintBottom_toTopOf="@+id/btnDatabases" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDatabases"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="90dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/kid_font"
        android:text="MY ALMANAC"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        app:autoSizeTextType="uniform"
        app:autoSizeMaxTextSize="28sp"
        app:autoSizeMinTextSize="16sp"
        app:backgroundTint="#29B6F6"
        app:cornerRadius="40dp"
        app:elevation="12dp"
        app:icon="@android:drawable/ic_menu_gallery"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="36dp"
        app:iconTint="#FFFFFF"
        app:layout_constraintWidth_percent="0.80"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnPlay"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMusicToggle"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="#FFEB3B"
        app:cornerRadius="30dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_lock_silent_mode_off"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="30dp"
        app:iconTint="#000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/btnAdmin"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/admin_pic"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cornerFamily="rounded"
        app:cornerSize="50%"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutOnboarding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF59D"
        android:elevation="50dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvWelcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kid_font"
            android:text="Welcome to LetterLand!"
            android:textColor="#000000"
            android:textSize="32sp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tvSubtitle"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/kid_font"
            android:text="Who is playing today?"
            android:textColor="#333333"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeTitle"
            app:layout_constraintBottom_toTopOf="@+id/etFirstPlayerName"/>

        <EditText
            android:id="@+id/etFirstPlayerName"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginTop="40dp"
            android:background="@android:drawable/editbox_background_normal"
            android:fontFamily="@font/kid_font"
            android:gravity="center"
            android:hint="Type your name..."
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textSize="24sp"
            app:layout_constraintWidth_percent="0.8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintBottom_toTopOf="@+id/btnStartPlaying"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartPlaying"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/kid_font"
            android:text="Let's Play!"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="40dp"
            app:elevation="8dp"
            app:layout_constraintWidth_percent="0.6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etFirstPlayerName"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>