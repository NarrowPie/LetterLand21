<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <ImageButton
        android:id="@+id/btnBackQuiz"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#F44336" />

    <TextView
        android:id="@+id/tvQuizProgress"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:fontFamily="@font/kid_font"
        android:gravity="center|start"
        android:text="1/10"
        android:textColor="#FF9800"
        android:includeFontPadding="false"
        app:autoSizeTextType="uniform"
        app:autoSizeMaxTextSize="40sp"
        app:autoSizeMinTextSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/btnBackQuiz"
        app:layout_constraintEnd_toStartOf="@id/cardQuizImage"
        app:layout_constraintStart_toEndOf="@id/btnBackQuiz"
        app:layout_constraintTop_toTopOf="@id/btnBackQuiz" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuizImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.25"
        app:strokeColor="#4CAF50"
        app:strokeWidth="5dp">

        <ImageView
            android:id="@+id/ivQuizImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/avatars" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvZoomHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/kid_font"
        android:text="🔎 Tap to zoom"
        android:textColor="#F44336"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/cardQuizImage"
        app:layout_constraintStart_toStartOf="@id/cardQuizImage"
        app:layout_constraintTop_toBottomOf="@id/cardQuizImage" />

    <LinearLayout
        android:id="@+id/llHangmanContainer"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvZoomHint">

        <TextView
            android:id="@+id/tvHangmanMask"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/kid_font"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:maxLines="1"
            android:text="L A B _ R A _ _ R Y"
            android:textColor="#9C27B0"
            android:textStyle="bold"
            android:includeFontPadding="false"
            app:autoSizeTextType="uniform"
            app:autoSizeMaxTextSize="32sp"
            app:autoSizeMinTextSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSpeakLiveText"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:text="🔊"
            android:textSize="22sp"
            app:backgroundTint="#FFCA28"
            app:cornerRadius="14dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llLiveTextContainer"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llHangmanContainer">

        <TextView
            android:id="@+id/tvLiveText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="@font/kid_font"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="..."
            android:textColor="#2196F3"
            app:autoSizeTextType="uniform"
            app:autoSizeMaxTextSize="38sp"
            app:autoSizeMinTextSize="16sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCanvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/llButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llLiveTextContainer"
        app:strokeColor="#29B6F6"
        app:strokeWidth="6dp">

        <com.example.letterland.DrawingView
            android:id="@+id/quizDrawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuizClear"
            android:layout_width="0dp"
            android:layout_height="75dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/kid_font"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="CLEAR"
            android:padding="8dp"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeMinTextSize="14sp"
            app:autoSizeTextType="uniform"
            app:backgroundTint="#F44336"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuizProceed"
            android:layout_width="0dp"
            android:layout_height="75dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/kid_font"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="SUBMIT"
            android:padding="8dp"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeMinTextSize="14sp"
            app:autoSizeTextType="uniform"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="24dp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBumper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivBumperLogo"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/title_logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvBumperLoading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvBumperLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/kid_font"
            android:text="Preparing Level..."
            android:textColor="#2196F3"
            android:textSize="28sp"
            app:layout_constraintTop_toBottomOf="@id/ivBumperLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/pbBumperLoading" />

        <ProgressBar
            android:id="@+id/pbBumperLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#4CAF50"
            app:layout_constraintTop_toBottomOf="@id/tvBumperLoading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btnBumperStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBumperStart"
            android:layout_width="200dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/kid_font"
            android:text="START"
            android:textSize="32sp"
            android:visibility="gone"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="24dp"
            app:layout_constraintTop_toBottomOf="@id/pbBumperLoading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>