<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#E1F5FE"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeColor="#29B6F6"
    app:strokeWidth="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kid_font"
            android:text="New Object!"
            android:textColor="#000000"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/kid_font"
            android:text="Type the word, then pick an image!"
            android:textColor="#333333"
            android:textSize="18sp"
            android:gravity="center" />

        <EditText
            android:id="@+id/etNewWordInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:background="@android:drawable/editbox_background_normal"
            android:fontFamily="@font/kid_font"
            android:gravity="center"
            android:hint="Type word here..."
            android:inputType="textCapWords"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGalleryAdd"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:fontFamily="@font/kid_font"
                android:text="Gallery"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                app:backgroundTint="#29B6F6"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_gallery"
                app:iconGravity="top"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmAdd"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:fontFamily="@font/kid_font"
                android:text="Camera"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconGravity="top"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelAdd"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:fontFamily="@font/kid_font"
                android:text="Cancel"
                android:textColor="#F44336"
                android:textSize="16sp"
                app:backgroundTint="@android:color/transparent"
                app:elevation="0dp"
                app:strokeWidth="0dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>