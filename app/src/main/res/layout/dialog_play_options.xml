<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFF9C4"
    app:cardCornerRadius="32dp"
    app:cardElevation="12dp"
    app:strokeColor="#FFB300"
    app:strokeWidth="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/kid_font"
            android:text="Choose Game Mode!"
            android:textColor="#E91E63"
            android:textSize="34sp"
            app:autoSizeTextType="uniform"
            android:maxLines="2"
            android:textStyle="bold"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWriteLetters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/kid_font"
            android:text="WRITE LETTERS"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMaxTextSize="24sp"
            app:autoSizeMinTextSize="14sp"
            app:backgroundTint="#FF9800"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconSize="32dp"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanWords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/kid_font"
            android:text="SCAN WORDS"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMaxTextSize="24sp"
            app:autoSizeMinTextSize="14sp"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart"
            app:iconSize="32dp"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuizMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/kid_font"
            android:text="QUIZ MODE"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMaxTextSize="24sp"
            app:autoSizeMinTextSize="14sp"
            app:backgroundTint="#9C27B0"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_menu_help"
            app:iconGravity="textStart"
            app:iconSize="32dp"
            app:iconTint="#FFFFFF" />

        <TextView
            android:id="@+id/tvQuizUnlockHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/kid_font"
            android:text="Collect 10 items in the Almanac to unlock!"
            android:textColor="#F44336"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelOptions"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kid_font"
            android:text="Cancel"
            android:textColor="#9E9E9E"
            android:textSize="22sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>